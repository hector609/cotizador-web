# Token del bot de Telegram. Usado SOLO para verificar el widget de Telegram
# Login (HMAC sobre los datos del usuario, según Telegram Login Widget docs).
# NO se usa para firmar la cookie de sesión.
TELEGRAM_BOT_TOKEN=

# Secreto exclusivo para firmar/verificar la cookie de sesión emitida por
# /api/auth/telegram. NO reutilizar TELEGRAM_BOT_TOKEN aquí: si uno se filtra,
# el otro también queda comprometido.
#
# Genera un valor con:
#   openssl rand -hex 32
SESSION_SECRET=
